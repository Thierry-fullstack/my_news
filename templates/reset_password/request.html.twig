{% extends 'base.html.twig' %}

{% block title %}Réinitialisation {% endblock %}
{% block importmap %}
    {{ importmap(['app', 'request-password']) }}
{% endblock %}
{% block body %}
    {% for flash_error in app.flashes('reset_password_error') %}
        <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
    {% endfor %}
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-md-8 py-5">
                <div class="card reset-card shadow rounded-1" id="reset-password-card">
                    <div class="card-body p-4">
                        <!-- Step  Email Verification -->
                        <div class="bg-white shadow-sm" >
                            <h1 class="card-title mb-3 text-center fst-italic text-dark">Email Verification</h1>
                        </div>
                        <hr class="text-warning" />
                        <div class="step-content" id="step-verification">
                            {{ form_start(requestForm,{ attr : { id:'resetPasswordForm',novalidate: 'novalidate'}}) }}
                            <div class="form-floating mb-3">
                                {{ form_widget(requestForm.email) }}
                                {{ form_label(requestForm.email)}}
                                <div class="text-danger small">
                                    {{ form_errors(requestForm.email)}}
                                </div>
                            </div>
                            <div class="text-warning fst-italic text-center mb-5">
                                <small>
                                    Nous vous enverrons un lien, après connaissance de votre adresse mail
                                </small>
                            </div>
                            <div class="d-grid">
                                {{ form_widget(requestForm.submit) }}
                                {{ form_label(requestForm.submit) }}
                            </div>
                            {{ form_end(requestForm) }}

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
