<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Confirmation mot de passe</title>
    <style>
        body{
            background-color:#fdfdfd;
        }
        article {
            min-height: 100%;
            display: grid;
            grid-template-rows: auto 1fr auto;
        }

        footer {
            display: flex;
            justify-content: center;
            padding: 5px;
            background-color: #FEFEFE;
            color: #0891b2;
        }
        .bouton-email{
            display: inline-block;
            outline: 0;
            border: 0;
            cursor: pointer;
            background-color: #0891b2;
            border-radius: 4px;
            padding: 8px 16px;
            font-size: 16px;
            font-weight: 700;
            color: white;
            line-height: 26px;

        }
        div{
            margin-bottom: 10px;
        }
        h2{
            color: #2E5273;
        }
        h1{
            color: rgb(8,145,178);
        }
    </style>
</head>
<body>
<article>
    <!-- Main Container -->
    <div>
        <!-- Header -->
        <div>
            <h1>Mon site.org</h1> {# changer par une variable dynamique #}
        </div>
    <!-- Content -->
        <div>
            <h2>Bonjour {{ user.email }} sur notre site</h2>

        <!-- CTA Button  -->
            <div>
                <p>
                    Pour réinitialiser votre mot de passe, veuillez suivre le lien suivant :
                </p>
                <a href="{{ url('app_reset_password', {token: resetToken.token}) }}" >
                    <button class="bouton-email">Réinitialisation mot de passe</button>
                </a>
                <p>Ce lien expire dans {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.</p>
                <p>Merci !</p>
            </div>
        </div>

        <!-- Footer -->
        <!-- Footer -->
        <footer>
            <p>© 2026 Thierry Dothée</p>
        </footer>
    </div>
</article>
</body>
</html>

